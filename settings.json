{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "gpt-5.4",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "GPT-5.4",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION": "Routed through local hybrid router",
    "CLAUDE_CODE_SUBAGENT_MODEL": "gpt-5.4-mini",
    "ECC_HOOK_PROFILE": "standard"
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/ORCHESTRATOR.md)",
      "Edit",
      "Write",
      "Skill",
      "WebSearch",
      "WebFetch",
      "mcp__plugin_figma_figma__get_metadata",
      "mcp__plugin_figma_figma__get_screenshot",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__pencil",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(command -v *)",
      "Bash(which *)",
      "Bash(mdls *)",
      "Bash(pdftotext *)",
      "Bash(pytest *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(uv run pytest *)",
      "Bash(ruff check *)",
      "Bash(.venv/bin/ruff check *)",
      "Bash(npm run test *)",
      "Bash(npm run build *)",
      "Bash(pnpm test *)",
      "Bash(pnpm build *)",
      "Bash(gh auth status *)",
      "Bash(gh pr view *)",
      "Bash(gh api *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh pr list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose ls *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker ps *)",
      "Bash(docker images *)",
      "Bash(docker stats *)",
      "Bash(colgrep *)",
      "Bash(* --help *)",
      "Bash(* --version)",
      "Read(./.env.example)",
      "Bash(curl * http://localhost:4000/*)",
      "Bash(curl * http://localhost:4000)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.npmrc)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "auto"
  },
  "model": "gpt-5.4",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/run-with-flags-shell.sh continuous-learning-v2-observe-post skills/continuous-learning-v2/hooks/observe.sh standard,strict post",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/pre-compact.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/run-with-flags.js suggest-compact hooks/suggest-compact.js standard,strict"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/run-with-flags-shell.sh continuous-learning-v2-observe-pre skills/continuous-learning-v2/hooks/observe.sh standard,strict pre",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash ~/.claude/hooks/ralph-controller-stop-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); agent=$(printf '%s' \"$input\" | jq -r '.agent.name // \"Claude\"' 2>/dev/null); cwd=$(printf '%s' \"$input\" | jq -r '.worktree.name // .worktree.branch // .workspace.project_dir // .workspace.current_dir // .cwd // empty' 2>/dev/null); [ -n \"$cwd\" ] || cwd=unknown; model=$(printf '%s' \"$input\" | jq -r '.model.display_name // empty' 2>/dev/null); remaining=$(printf '%s' \"$input\" | jq -r 'if .context_window.remaining_percentage == null then \"\" else (.context_window.remaining_percentage | floor | tostring) end' 2>/dev/null); used=$(printf '%s' \"$input\" | jq -r 'if .context_window.used_percentage == null then \"\" else (.context_window.used_percentage | floor | tostring) end' 2>/dev/null); vim_mode=$(printf '%s' \"$input\" | jq -r '.vim.mode // empty' 2>/dev/null); ctx_color='2'; if [ -n \"$remaining\" ]; then if [ \"$remaining\" -le 15 ] 2>/dev/null; then ctx_color='1;31'; elif [ \"$remaining\" -le 35 ] 2>/dev/null; then ctx_color='38;5;214'; else ctx_color='1;32'; fi; fi; printf '\\033[2m'; printf '◦ '; printf '\\033[1;36m%s\\033[0m' \"$agent\"; if [ -n \"$model\" ] && [ \"$model\" != \"$agent\" ]; then printf ' \\033[2m·\\033[0m \\033[2m%s\\033[0m' \"$model\"; fi; printf ' \\033[2m·\\033[0m '; printf '\\033[1;33m%s\\033[0m' \"$cwd\"; if [ -n \"$remaining\" ]; then printf ' \\033[2m·\\033[0m \\033[%sm%s%% left\\033[0m' \"$ctx_color\" \"$remaining\"; elif [ -n \"$used\" ]; then printf ' \\033[2m·\\033[0m \\033[2m%s%% used\\033[0m' \"$used\"; fi; if [ -n \"$vim_mode\" ]; then printf ' \\033[2m·\\033[0m \\033[2m%s\\033[0m' \"$vim_mode\"; fi"
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": false,
    "clangd-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "colgrep@lightonai-colgrep": true,
    "huggingface-skills@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "lightonai-colgrep": {
      "source": {
        "source": "directory",
        "path": "/Users/liamvdb/Library/Application Support/colgrep/claude-marketplace"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.npmrc",
        "~/.claude"
      ]
    },
    "excludedCommands": [
      "docker"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voice": {
    "enabled": false
  },
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
