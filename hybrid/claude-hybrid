#!/usr/bin/env bash
set -euo pipefail

PROXY_PID=""

PORT="$(python3 -c 'import socket; s=socket.socket(); s.bind(("127.0.0.1", 0)); print(s.getsockname()[1]); s.close()')"

cleanup() {
  if [[ -n "${PROXY_PID}" ]]; then
    kill "${PROXY_PID}" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

export ANTHROPIC_BASE_URL="http://127.0.0.1:${PORT}"
export HYBRID_LITELLM_BASE_URL="${HYBRID_LITELLM_BASE_URL:-https://litellm.juphorizon.com}"
export ANTHROPIC_CUSTOM_MODEL_OPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION:-gpt-5.5[1m]}"
export ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="${ANTHROPIC_CUSTOM_MODEL_OPTION_NAME:-GPT-5.5 1M}"
export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION:-Routed through local hybrid router}"

HYBRID_PROXY_PORT="${PORT}" node "${HOME}/.claude/hybrid/http-proxy.js" >/dev/null 2>&1 &
PROXY_PID=$!

for _ in $(seq 1 100); do
  if python3 -c 'import socket, sys; s=socket.socket(); s.settimeout(0.1); rc=s.connect_ex(("127.0.0.1", int(sys.argv[1]))); s.close(); raise SystemExit(0 if rc == 0 else 1)' "${PORT}"; then
    break
  fi

  if ! kill -0 "${PROXY_PID}" 2>/dev/null; then
    echo "ERROR: proxy exited before listening on 127.0.0.1:${PORT}" >&2
    exit 1
  fi

  sleep 0.1
done

if ! python3 -c 'import socket, sys; s=socket.socket(); s.settimeout(0.1); rc=s.connect_ex(("127.0.0.1", int(sys.argv[1]))); s.close(); raise SystemExit(0 if rc == 0 else 1)' "${PORT}"; then
  echo "ERROR: proxy did not start listening on 127.0.0.1:${PORT}" >&2
  exit 1
fi

exec claude "$@"
