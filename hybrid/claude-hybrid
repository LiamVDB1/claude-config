#!/usr/bin/env bash
set -euo pipefail

SOCKET_PATH="${TMPDIR:-/tmp}/claude-hybrid-$$.sock"
SOCKET_SERVER_PID=""

get_oauth_token() {
  local credentials_json
  credentials_json="$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null)"
  if [[ -z "$credentials_json" ]]; then
    echo "ERROR: Could not read Claude Code credentials from macOS Keychain" >&2
    return 1
  fi

  python3 -c '
import json, sys
payload = json.loads(sys.stdin.read())
token = payload.get("claudeAiOauth", {}).get("accessToken", "")
if not token:
    raise SystemExit(1)
print(token, end="")
' <<<"$credentials_json"
}

cleanup() {
  if [[ -n "${SOCKET_SERVER_PID}" ]]; then
    kill "${SOCKET_SERVER_PID}" 2>/dev/null || true
  fi
  rm -f "${SOCKET_PATH}"
}
trap cleanup EXIT INT TERM

unset ANTHROPIC_BASE_URL ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN
unset ANTHROPIC_DEFAULT_SONNET_MODEL ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_HAIKU_MODEL

export CLAUDE_CODE_OAUTH_TOKEN="$(get_oauth_token)"
export ANTHROPIC_UNIX_SOCKET="${SOCKET_PATH}"
export HYBRID_LITELLM_BASE_URL="${HYBRID_LITELLM_BASE_URL:-https://litellm.juphorizon.com}"
export ANTHROPIC_CUSTOM_MODEL_OPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION:-gpt-5.4}"
export ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="${ANTHROPIC_CUSTOM_MODEL_OPTION_NAME:-GPT-5.4}"
export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION:-Routed through local hybrid router}"

node "${HOME}/.claude/hybrid/socket-server.js" >/dev/null 2>&1 &
SOCKET_SERVER_PID=$!

for _ in $(seq 1 50); do
  [[ -S "${SOCKET_PATH}" ]] && break
  if ! kill -0 "${SOCKET_SERVER_PID}" 2>/dev/null; then
    echo "ERROR: socket server exited before creating ${SOCKET_PATH}" >&2
    exit 1
  fi
  sleep 0.1
done

if [[ ! -S "${SOCKET_PATH}" ]]; then
  echo "ERROR: socket server did not start" >&2
  exit 1
fi

export NODE_TLS_REJECT_UNAUTHORIZED="${NODE_TLS_REJECT_UNAUTHORIZED:-0}"
exec claude "$@"
